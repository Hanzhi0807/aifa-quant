# iFind MCP Configuration
# Copy this file to .env and fill in your real tokens.
# NEVER commit .env to git.

IFIND_STOCK_MCP_URL=https://api-mcp.51ifind.com:8643/ds-mcp-servers/hexin-ifind-ds-stock-mcp
IFIND_STOCK_MCP_TOKEN=your_stock_token_here

IFIND_EDB_MCP_URL=https://api-mcp.51ifind.com:8643/ds-mcp-servers/hexin-ifind-ds-edb-mcp
IFIND_EDB_MCP_TOKEN=your_edb_token_here

IFIND_NEWS_MCP_URL=https://api-mcp.51ifind.com:8643/ds-mcp-servers/hexin-ifind-ds-news-mcp
IFIND_NEWS_MCP_TOKEN=your_news_token_here

IFIND_INDEX_MCP_URL=https://api-mcp.51ifind.com:8643/ds-mcp-servers/hexin-ifind-ds-index-mcp
IFIND_INDEX_MCP_TOKEN=your_index_token_here

# Project settings
DATA_DIR=./data_store
DUCKDB_PATH=./data_store/aifa_quant.duckdb
# Supabase cloud dashboard (optional)
# Service role key is server-side only; never expose it in signals-web/Vercel.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# signals-web local development only. In Vercel, set these in Project Settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
