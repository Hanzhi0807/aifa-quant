# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
# MySQL connection string format:
#   mysql://<用户名>:<密码>@<主机>:<端口>/<数据库名>
# 示例（本地 MySQL，用户 root，密码 123456，数据库 aifa_quant）：
# DATABASE_URL=mysql://root:123456@localhost:3306/aifa_quant
#
# 如果暂时没有 MySQL，可以留空，前端会自动使用 mock 数据。
DATABASE_URL=
